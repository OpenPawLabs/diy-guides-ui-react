{
  "name": "@openpawlabs/diy-guides-ui",
  "version": "1.5.1",
  "description": "React UI library for building open-source, iFixit-style step-by-step diy guides",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "main": "./dist/diy-guides-ui.cjs",
  "module": "./dist/diy-guides-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/diy-guides-ui.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/diy-guides-ui.cjs"
      }
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build && tsc -b tsconfig.app.json",
    "build:storybook": "storybook build -o storybook-static",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "build:publish": "pnpm build && npm publish"
  },
  "peerDependencies": {
    "online-3d-viewer": "^0.18.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@heroui/react": "^3.0.0",
    "@heroui/styles": "^3.0.0",
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/addon-links": "^9.1.20",
    "@storybook/addon-themes": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^9.0.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^9.0.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "online-3d-viewer": "^0.18.0"
  }
}
